{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth?_p=:path*" },
    { "source": "/api/admin/:path*", "destination": "/api/admin?_p=:path*" },
    { "source": "/api/cbt/:path*", "destination": "/api/cbt?_p=:path*" },
    { "source": "/api/pay/:path*", "destination": "/api/pay?_p=:path*" },
    { "source": "/api/feedback/:path*", "destination": "/api/feedback?_p=:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; connect-src 'self' https://api.flutterwave.com https://flutterwave.com; img-src 'self' data: https://www.fcta.gov.ng https://*.vercel.app; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; frame-src https:; frame-ancestors 'none';" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}
